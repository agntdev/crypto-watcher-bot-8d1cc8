[
  {
    "name": "Manage Alerts empty watchlist",
    "steps": [
      {
        "send": { "callback": "alerts:manage" },
        "expect": [
          {
            "method": "editMessageText",
            "payload": {
              "text": "Manage alerts — threshold or percent-move rules.\n\nNo alert rules yet — pick a coin to create one.\n\nYour watchlist is empty — tap Add Coin to add BTC, ETH, or TON."
            }
          }
        ]
      }
    ]
  },
  {
    "name": "create threshold alert flow",
    "steps": [
      {
        "send": { "callback": "add_coin:pick:BTC" },
        "expect": [{ "method": "sendMessage" }]
      },
      {
        "send": { "callback": "alerts:manage" },
        "expect": [{ "method": "editMessageText" }]
      },
      {
        "send": { "callback": "alerts:coin:BTC" },
        "expect": [
          {
            "method": "editMessageText",
            "payload": {
              "text": "Alert for BTC.\n\nChoose a type:\n• Threshold — fire when price crosses a USD level\n• Percent move — fire on a % change over 1 hour"
            }
          }
        ]
      },
      {
        "send": { "callback": "alerts:type:threshold" },
        "expect": [
          {
            "method": "editMessageText",
            "payload": {
              "text": "Direction for BTC: alert when price goes…"
            }
          }
        ]
      },
      {
        "send": { "callback": "alerts:dir:above" },
        "expect": [
          {
            "method": "editMessageText",
            "payload": {
              "text": "Threshold for BTC (above).\n\nSend the USD price (e.g. 65000)."
            }
          }
        ]
      },
      {
        "send": { "text": "65000" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "Saved: alert when BTC goes above 65000 USD."
            }
          }
        ]
      }
    ]
  },
  {
    "name": "create percent alert flow",
    "steps": [
      {
        "send": { "callback": "add_coin:pick:ETH" },
        "expect": [{ "method": "sendMessage" }]
      },
      {
        "send": { "callback": "alerts:coin:ETH" },
        "expect": [{ "method": "editMessageText" }]
      },
      {
        "send": { "callback": "alerts:type:percent" },
        "expect": [
          {
            "method": "editMessageText",
            "payload": {
              "text": "Percent move for ETH.\n\nSend the percent (e.g. 5 for 5%). Timeframe is 1 hour."
            }
          }
        ]
      },
      {
        "send": { "text": "5" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "Saved: alert when ETH moves 5% within 1 hour."
            }
          }
        ]
      }
    ]
  }
]
